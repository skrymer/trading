{
  "conditions": [
    {
      "type": "script",
      "parameters": {
        "script": "val prev = stock.getPreviousQuote(quote)\nif (prev == null || prev.closePrice <= 0.0 || prev.atr <= 0.0) false\nelse {\n  val qd = quote.date\n  val e = stock.earnings.filter { it.reportedDate != null && it.reportedDate!!.year > 1900 && !it.reportedDate!!.isAfter(qd) }.maxByOrNull { it.reportedDate!! }\n  if (e == null) false\n  else {\n    val rd = e.reportedDate!!\n    val before = e.reportTime == \"BeforeMarket\"\n    val gapDay = if (before) !qd.isBefore(rd) && prev.date.isBefore(rd) else qd.isAfter(rd) && !prev.date.isAfter(rd)\n    if (!gapDay || stock.countTradingDaysBetween(rd, qd) > 3) false\n    else {\n      val spyG = context.getSpyQuote(qd)\n      val spyPrev = context.getSpyQuote(prev.date)\n      if (spyG == null || spyPrev == null || spyPrev.atr <= 0.0) false\n      else {\n        val nameGap = (quote.openPrice - prev.closePrice) / prev.atr\n        val spyGap = (spyG.openPrice - spyPrev.closePrice) / spyPrev.atr\n        val residualAtr = nameGap - spyGap\n        residualAtr >= {{theta}} && e.beatEstimates()\n      }\n    }\n  }\n}"
      }
    }
  ],
  "operator": "AND",
